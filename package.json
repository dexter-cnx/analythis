{
  "name": "@dextercnx/analythis",
  "version": "1.0.0",
  "description": "Framework-agnostic repository analysis engine that turns codebases into blueprints, reports, and prompt packs.",
  "license": "MIT",
  "author": "Kitipong Sarajan <cnxcoder@gmail.com>",
  "homepage": "https://github.com/dexter-cnx/analythis#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/dexter-cnx/analythis.git"
  },
  "bugs": {
    "url": "https://github.com/dexter-cnx/analythis/issues"
  },
  "type": "commonjs",
  "bin": {
    "analythis": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "schemas",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist .analythis tmp",
    "dev": "ts-node src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "repository-analysis",
    "reverse-engineering",
    "blueprint",
    "cli",
    "architecture"
  ],
  "dependencies": {
    "commander": "^14.0.1",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.6.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
